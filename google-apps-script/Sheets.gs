function hubDb(){ const files=DriveApp.getFilesByName(HUB_CONFIG.DB_SHEET_NAME); if(files.hasNext()) return SpreadsheetApp.open(files.next()); return SpreadsheetApp.create(HUB_CONFIG.DB_SHEET_NAME); }
function readExternalSheet(id, origem){ if(!id) return []; const sh=SpreadsheetApp.openById(id).getSheets()[0]; const vals=sh.getDataRange().getValues(); if(vals.length<2) return []; const head=vals.shift().map(h=>String(h).toLowerCase().trim()); return vals.filter(r=>r.join('').trim()).map((r,i)=>({ id:origem+'_'+i, titulo:value(r,head,['titulo','nome','disciplina','evento','prova','tarefa'])||origem, data:fmt(value(r,head,['data','dia','date'])), hora:value(r,head,['hora','time'])||'', membro:value(r,head,['membro','aluno','atleta','pessoa'])||'Todos', origem, notas:value(r,head,['notas','obs','observacoes','observações'])||'' })).filter(x=>x.data); }
function value(r,h,names){ for(let n of names){ const i=h.indexOf(n); if(i>=0) return r[i]; } return ''; }
function fmt(v){ if(v instanceof Date) return Utilities.formatDate(v, Session.getScriptTimeZone(), 'yyyy-MM-dd'); return String(v||'').slice(0,10); }
function backupCreate(req){ const ss=hubDb(); const sh=ss.getSheetByName('BACKUPS')||ss.insertSheet('BACKUPS'); sh.appendRow([new Date(), JSON.stringify(req)]); return {ok:true, sheet:ss.getUrl()}; }
function syncAll(req){ const cal=calendarList(); const study=studyImport(); const swim=swimImport(); return { ok:true, calendar:cal.calendar, events:cal.events, study:study.items, swim:swim.items, message:'RJP Hub sincronizado' }; }
